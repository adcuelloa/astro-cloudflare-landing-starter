---
import HeroSection from "@/components/home/HeroSection.astro";
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";
import { alternateLinks } from "@/i18n/slugs";
import { getPageSeo } from "@/lib/seo";

const lang = "en";
const t = useTranslations(lang);
const site =
  Astro.site ??
  new URL(import.meta.env.PUBLIC_SITE_URL ?? "https://acme.example.com");
const alternates = alternateLinks("home", site);
const pageSeo = getPageSeo(lang, "home");

type Feature = { title: string; body: string };
type Faq = { q: string; a: string };
const features = t("home.features.items") as Feature[];
const faqs = t("home.faq.items") as Faq[];
---

<Layout seo={{ ...pageSeo, alternates }}>
  <main class="text-slate-800">
    <HeroSection />

    <section class="bg-slate-50 py-16 sm:py-24" data-scroll-reveal>
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="max-w-3xl">
          <p class="eyebrow mb-3">{t("home.features.eyebrow")}</p>
          <h2>{t("home.features.title")}</h2>
          <p class="lead mt-4">{t("home.features.lead")}</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {
            features.map((feature) => (
              <article class="card p-6">
                <h3 class="text-lg">{feature.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                  {feature.body}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24" data-scroll-reveal>
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-2">
        <div>
          <p class="eyebrow mb-3">{t("home.faq.eyebrow")}</p>
          <h2>{t("home.faq.title")}</h2>
        </div>
        <div class="space-y-3">
          {
            faqs.map((item) => (
              <details class="rounded-md border border-slate-200 bg-white p-5">
                <summary class="font-display cursor-pointer font-bold text-slate-800">
                  {item.q}
                </summary>
                <p class="mt-3 text-sm text-slate-600">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
