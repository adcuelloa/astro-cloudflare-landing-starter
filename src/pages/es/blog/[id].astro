---
import { getCollection, getEntries, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";
import { localizedPath } from "@/i18n/slugs";
import {
  entryLocale,
  localizedCollectionEntryPath,
  localizedEntryPath,
} from "@/lib/contentRouting";
import { blogPostingSchema, breadcrumbSchema, contentSeo, contentSlug } from "@/lib/seo";

const lang = "es";
const t = useTranslations(lang);
const site = Astro.site ?? new URL(import.meta.env.PUBLIC_SITE_URL ?? "https://acme.example.com");

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ id }) => id.startsWith("es/"));
  return posts.map((post) => ({
    params: { id: contentSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const frontmatter = remarkPluginFrontmatter as { readTime?: number };
const categoryEntries = await getEntries(post.data.categories);
const authorEntries = await getEntries(post.data.authors);
const translationEntries = await getEntries(post.data.translations ?? []);

const postUrl = new URL(localizedEntryPath(lang, "blog", post), site).href;
const blogUrl = new URL(localizedPath(lang, "blog"), site).href;

// hreflang alternates: current post + every linked translation.
const alternates = [
  { hreflang: lang, href: postUrl },
  ...translationEntries.map((entry) => ({
    hreflang: entryLocale(entry),
    href: new URL(localizedCollectionEntryPath("blog", entry), site).href,
  })),
];

const heroImage = post.data.image;
const heroImageAlt = post.data.imageAlt ?? "";

const dateFormatter = new Intl.DateTimeFormat("es", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const seo = {
  ...contentSeo(post.data),
  canonicalUrl: postUrl,
  alternates,
  ogType: "article",
  publishedTime: post.data.pubDate.toISOString(),
  updatedTime: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  structuredData: [
    breadcrumbSchema([
      { name: "Inicio", url: new URL(localizedPath(lang, "home"), site).href },
      { name: t("blog.breadcrumb"), url: blogUrl },
      { name: post.data.title, url: postUrl },
    ]),
    blogPostingSchema({
      authors: authorEntries.map((a) => a.data.name),
      categories: categoryEntries.map((c) => c.data.title),
      description: post.data.description,
      image: post.data.image,
      imageAlt: post.data.imageAlt,
      lang,
      published: post.data.pubDate,
      title: post.data.title,
      updated: post.data.updatedDate,
      url: postUrl,
    }),
  ],
} as const;
---

<Layout seo={seo}>
  <main class="bg-slate-50 text-slate-800">
    <section class="py-12 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <a class="font-display text-brand-800 text-sm font-bold" href={localizedPath(lang, "blog")}>
          ← {t("blog.backToList")}
        </a>
        <p class="eyebrow mt-8 mb-3">{categoryEntries.map((c) => c.data.title).join(", ")}</p>
        <h1>{post.data.title}</h1>
        <p class="lead mt-4">{post.data.description}</p>
        <div
          class="mt-6 flex flex-wrap gap-3 border-t border-slate-200 pt-4 text-sm text-slate-500"
        >
          <span>{t("blog.publishedOn")}{dateFormatter.format(post.data.pubDate)}</span>
          <span>·</span>
          <span>{frontmatter.readTime ?? 1} min {t("blog.readLabel")}</span>
          <span>·</span>
          <span>{authorEntries.map((a) => a.data.name).join(", ")}</span>
        </div>
        {
          heroImage ? (
            <Image
              src={heroImage}
              alt={heroImageAlt}
              width={1200}
              height={675}
              format="webp"
              quality={82}
              widths={[480, 640, 720, 960, 1200]}
              sizes="(min-width: 768px) 720px, calc(100vw - 2rem)"
              priority
              loading="eager"
              decoding="async"
              class="mt-8 aspect-video w-full rounded-lg border border-slate-200 bg-slate-100 object-cover shadow-sm"
            />
          ) : null
        }
      </div>
    </section>
    <section class="bg-white py-12 sm:py-20">
      <article class="prose mx-auto max-w-3xl px-4 sm:px-6">
        <Content />
      </article>
    </section>
  </main>
</Layout>
