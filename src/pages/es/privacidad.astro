---
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";
import { alternateLinks } from "@/i18n/slugs";
import { getPageSeo } from "@/lib/seo";

const lang = "es";
const t = useTranslations(lang);
const site = Astro.site ?? new URL(import.meta.env.PUBLIC_SITE_URL ?? "https://acme.example.com");
const pageSeo = getPageSeo(lang, "legalPrivacy");
const body = t("legal.privacy.body") as string[];
---

<Layout seo={{ ...pageSeo, alternates: alternateLinks("legalPrivacy", site) }}>
  <main class="bg-white py-16 sm:py-24">
    <section class="prose mx-auto max-w-3xl px-4 sm:px-6">
      <h1>{t("legal.privacy.heading")}</h1>
      <p class="text-sm text-slate-500">{t("legal.privacy.updated")}</p>
      {body.map((p) => <p>{p}</p>)}
    </section>
  </main>
</Layout>
