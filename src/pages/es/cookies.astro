---
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";
import { alternateLinks } from "@/i18n/slugs";
import { getPageSeo } from "@/lib/seo";

const lang = "es";
const t = useTranslations(lang);
const site = Astro.site ?? new URL(import.meta.env.PUBLIC_SITE_URL ?? "https://acme.example.com");
const pageSeo = getPageSeo(lang, "legalCookies");
const body = t("legal.cookies.body") as string[];
---

<Layout seo={{ ...pageSeo, alternates: alternateLinks("legalCookies", site) }}>
  <main class="bg-white py-16 sm:py-24">
    <section class="prose mx-auto max-w-3xl px-4 sm:px-6">
      <h1>{t("legal.cookies.heading")}</h1>
      <p class="text-sm text-slate-500">{t("legal.cookies.updated")}</p>
      {body.map((p) => <p>{p}</p>)}
      <p>
        <button
          type="button"
          data-cookie-settings
          class="text-brand-700 hover:text-brand-800 underline underline-offset-4"
        >
          {t("common.footer.cookieSettings")}
        </button>
      </p>
    </section>
  </main>
</Layout>
