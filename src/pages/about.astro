---
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";
import { alternateLinks } from "@/i18n/slugs";
import { getPageSeo } from "@/lib/seo";

const lang = "en";
const t = useTranslations(lang);
const site = Astro.site ?? new URL(import.meta.env.PUBLIC_SITE_URL ?? "https://acme.example.com");
const pageSeo = getPageSeo(lang, "about");
---

<Layout seo={{ ...pageSeo, alternates: alternateLinks("about", site) }}>
  <main class="bg-white py-16 sm:py-24">
    <section class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="eyebrow mb-3">{t("about.eyebrow")}</p>
      <h1>{t("about.heading")}</h1>
      <p class="lead mt-4">{t("about.lead")}</p>
      <h2 class="mt-12 text-2xl">{t("about.missionTitle")}</h2>
      <p class="mt-3 text-slate-600">{t("about.missionText")}</p>
    </section>
  </main>
</Layout>
