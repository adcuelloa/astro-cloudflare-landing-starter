---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { type Locale, localizedPath } from "@/i18n/slugs";

const lang = getLangFromUrl(Astro.url) as Locale;
const t = useTranslations(lang);
---

<section data-hero class="relative overflow-hidden bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="max-w-3xl">
      <p class="eyebrow mb-4">{t("home.hero.eyebrow")}</p>
      <h1 class="display">{t("home.hero.title")}</h1>
      <p class="lead mt-6 max-w-2xl">{t("home.hero.lead")}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={localizedPath(lang, "blog")}
          class="font-display bg-brand-700 hover:bg-brand-800 inline-flex rounded-full px-6 py-3 text-sm font-bold text-white no-underline transition"
          data-zaraz-cta="hero-primary"
        >
          {t("home.hero.ctaPrimary")}
        </a>
        <a
          href={localizedPath(lang, "about")}
          class="font-display hover:border-brand-500 hover:text-brand-800 inline-flex rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-bold text-slate-800 no-underline transition"
          data-zaraz-cta="hero-secondary"
        >
          {t("home.hero.ctaSecondary")}
        </a>
      </div>
    </div>
  </div>
</section>
